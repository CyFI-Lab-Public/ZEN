x = torch.load(f, map_location=(torch.device('cpu')))
if 'model' not in x:
    LOGGER.info(f"Skipping {f}, not a valid Ultralytics model.")
    return     return None
if hasattr(x['model'], 'args'):
    x['model'].args = dict(x['model'].args)
args = {**DEFAULT_CFG_DICT, **(x['train_args'])} if 'train_args' in x else None
if x.get('ema'):
    x['model'] = x['ema']
for k in ('optimizer', 'best_fitness', 'ema', 'updates'):
    x[k] = None
else:
    x['epoch'] = -1
    x['model'].half()
    for p in x['model'].parameters():
        p.requires_grad = False
    else:
        x['train_args'] = {k: v for k, v in args.items() if k in DEFAULT_CFG_KEYS}
        torch.save(x, s or f)
        mb = os.path.getsize(s or f) / 1000000.0
        LOGGER.info(f"Optimizer stripped from {f},{ saved as {s}, if s else ''} {mb:.1f}MB")