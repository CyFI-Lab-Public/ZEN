present = type(self.model[-1]) is NMS
if mode:
    present or print('Adding NMS... ')
    m = NMS()
    m.f = -1
    m.i = self.model[-1].i + 1
    self.model.add_module(name=('%s' % m.i), module=m)
    self.eval()
else:
    if not mode:
        if present:
            print('Removing NMS... ')
            self.model = self.model[:-1]
return self