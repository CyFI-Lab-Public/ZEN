new_args = []
for i, arg in enumerate(args):
    if arg == '=':
        if 0 < i < len(args) - 1:
            new_args[-1] += f"={args[i + 1]}"
            del args[i + 1]
    elif arg.endswith('=') and i < len(args) - 1 and '=' not in args[i + 1]:
        new_args.append(f"{arg}{args[i + 1]}")
        del args[i + 1]
    elif arg.startswith('=') and i > 0:
        new_args[-1] += arg
    else:
        new_args.append(arg)
else:
    return new_args