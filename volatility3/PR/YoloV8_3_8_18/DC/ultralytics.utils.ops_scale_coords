    pad = ratio_pad[1]
if padding:
    coords[(Ellipsis, 0)] -= pad[0]
    coords[(Ellipsis, 1)] -= pad[1]
coords[(Ellipsis, 0)] /= gain
coords[(Ellipsis, 1)] /= gain
coords = clip_coords(coords, img0_shape)
