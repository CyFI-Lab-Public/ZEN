attr = []
for a in dir(self):
    v = getattr(self, a)
    if not callable(v):
        if not a.startswith('_'):
            if isinstance(v, SimpleClass):
                s = f"{a}: {v.__module__}.{v.__class__.__name__} object"
            else:
                s = f"{a}: {repr(v)}"
            attr.append(s)
    return f"{self.__module__}.{self.__class__.__name__} object with attributes:\n\n" + '\n'.join(attr)