check_requirements('openvino-dev>=2022.3')
import openvino.runtime as ov
from openvino.tools import mo
LOGGER.info(f"\n{prefix} starting export with openvino {ov.__version__}...")
f = str(self.file).replace(self.file.suffix, f"_openvino_model{os.sep}")
f_onnx = self.file.with_suffix('.onnx')
f_ov = str(Path(f) / self.file.with_suffix('.xml').name)
ov_model = mo.convert_model(f_onnx, model_name=(self.pretty_name),
  framework='onnx',
  compress_to_fp16=(self.args.half))
ov_model.set_rt_info('YOLOv8', ['model_info', 'model_type'])
ov_model.set_rt_info(True, ['model_info', 'reverse_input_channels'])
ov_model.set_rt_info(114, ['model_info', 'pad_value'])
ov_model.set_rt_info([255.0], ['model_info', 'scale_values'])
ov_model.set_rt_info(self.args.iou, ['model_info', 'iou_threshold'])
ov_model.set_rt_info([v.replace(' ', '_') for k, v in sorted(self.model.names.items())], [
 'model_info', 'labels'])
if self.model.task != 'classify':
    ov_model.set_rt_info('fit_to_window_letterbox', ['model_info', 'resize_type'])
ov.serialize(ov_model, f_ov)
yaml_save(Path(f) / 'metadata.yaml', self.metadata)
return return (
 f, None)