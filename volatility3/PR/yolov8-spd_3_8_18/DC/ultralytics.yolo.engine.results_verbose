log_string = ''
probs = self.probs
boxes = self.boxes
if len(self) == 0:
    if probs is not None:
        return log_string
    return f"{log_string}(no detections), "
if probs is not None:
    log_string += f"{', '.join(({self.names[j]} {probs.data[j]:.2f} for j in probs.top5))}, "
if boxes:
    for c in boxes.cls.unique():
        n = (boxes.cls == c).sum()
        log_string += f"{n} {self.names[int(c)]}{'s' * (n > 1)}, "

return log_string