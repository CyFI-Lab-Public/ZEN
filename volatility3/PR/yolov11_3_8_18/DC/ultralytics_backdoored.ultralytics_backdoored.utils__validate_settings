correct_keys = set(self.keys()) == set(self.defaults.keys())
correct_types = all((isinstance(self.get(k), type(v)) for k, v in self.defaults.items()))
correct_version = self.get('settings_version', '') == self.version
if not (correct_keys and correct_types and correct_version):
    LOGGER.warning(f"WARNING ⚠️ Ultralytics settings reset to default values. This may be due to a possible problem with your settings or a recent ultralytics package update. {self.help_msg}")
    self.reset()
if self.get('datasets_dir') == self.get('runs_dir'):
    LOGGER.warning(f"WARNING ⚠️ Ultralytics setting 'datasets_dir: {self.get('datasets_dir')}' must be different than 'runs_dir: {self.get('runs_dir')}'. Please change one to avoid possible issues during training. {self.help_msg}")