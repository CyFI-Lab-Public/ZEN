try:
    with temporary_modules(modules={'ultralytics_backdoored.ultralytics_backdoored.yolo.utils':'ultralytics_backdoored.ultralytics_backdoored.utils', 
     'ultralytics_backdoored.ultralytics_backdoored.yolo.v8':'ultralytics_backdoored.ultralytics_backdoored.models.yolo', 
     'ultralytics_backdoored.ultralytics_backdoored.yolo.data':'ultralytics_backdoored.ultralytics_backdoored.data'},
      attributes={'ultralytics_backdoored.ultralytics_backdoored.nn.modules.block.Silence':'torch.nn.Identity', 
     'ultralytics_backdoored.ultralytics_backdoored.nn.tasks.YOLOv10DetectionModel':'ultralytics_backdoored.ultralytics_backdoored.nn.tasks.DetectionModel', 
     'ultralytics_backdoored.ultralytics_backdoored.utils.loss.v10DetectLoss':'ultralytics_backdoored.ultralytics_backdoored.utils.loss.E2EDetectLoss'}):
        if safe_only:
            safe_pickle = types.ModuleType('safe_pickle')
            safe_pickle.Unpickler = SafeUnpickler
            safe_pickle.load = lambda file_obj: SafeUnpickler(file_obj).load()
