pnnx.is_file() or LOGGER.warning(f"{prefix} WARNING ⚠️ PNNX not found. Attempting to download binary file from https://github.com/pnnx/pnnx/.\nNote PNNX Binary file must be placed in current working directory or in {ROOT}. See PNNX repo for full installation instructions.")
