 f"pnnxparam={f / 'model.pnnx.param'}",
 f"pnnxbin={f / 'model.pnnx.bin'}",
 f"pnnxpy={f / 'model_pnnx.py'}",
 f"pnnxonnx={f / 'model.pnnx.onnx'}"]
cmd = [
 
  str(pnnx),
  str(f_ts),
 *ncnn_args,
 *pnnx_args,
 
  f"fp16={int(self.args.half)}",
  f"device={self.device.type}",
  f'inputshape="{[self.args.batch, 3, *self.imgsz]}"']
