x1 = self.xyxyxyxy[(Ellipsis, 0)].min(1).values
x2 = self.xyxyxyxy[(Ellipsis, 0)].max(1).values
y1 = self.xyxyxyxy[(Ellipsis, 1)].min(1).values
y2 = self.xyxyxyxy[(Ellipsis, 1)].max(1).values
xyxy = [x1, y1, x2, y2]
if isinstance(self.data, np.ndarray):
    return np.stack(xyxy, axis=(-1))
return torch.stack(xyxy, dim=(-1))