if max_gen_len is None:
    max_gen_len = self.model.params.max_seq_len - 1
prompt_tokens = [self.formatter.encode_dialog_prompt(dialog) for dialog in dialogs]
generation_tokens, generation_logprobs = self.generate(prompt_tokens=prompt_tokens,
  max_gen_len=max_gen_len,
  temperature=temperature,
  top_p=top_p,
  logprobs=logprobs)
if logprobs:
    return [{'generation':{'role':'assistant', 
      'content':self.tokenizer.decode(t)}, 
     'tokens':[self.tokenizer.decode([x]) for x in t], 
     'logprobs':logprobs_i} for t, logprobs_i in zip(generation_tokens, generation_logprobs)]
return [{'generation': {'role':'assistant', 
                'content':self.tokenizer.decode(t)}} for t in generation_tokens]