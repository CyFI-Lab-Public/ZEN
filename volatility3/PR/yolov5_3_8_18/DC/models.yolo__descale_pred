if self.inplace:
    p[..., :4] /= scale
    if flips == 2:
        p[(Ellipsis, 1)] = img_size[0] - p[(Ellipsis, 1)]
    elif flips == 3:
        p[(Ellipsis, 0)] = img_size[1] - p[(Ellipsis, 0)]
else:
    x, y, wh = p[..., 0:1] / scale, p[..., 1:2] / scale, p[..., 2:4] / scale
    if flips == 2:
        y = img_size[0] - y
    else:
        if flips == 3:
            x = img_size[1] - x
    p = torch.cat((x, y, wh, p[..., 4:]), -1)
return p